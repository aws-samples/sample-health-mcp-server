{
  "mcpServers": {
    "aws-health1": {
      "command": "/Users/jsanketh/Desktop/AWS_Health_MCP/test_env/bin/python3",
      "args": [
        "-m",
        "awslabs.aws_health_mcp_server"
      ],
      "env": {},
      "disabled": false,
      "autoApprove": [
        "get_service_health",
        "get_org_health_events",
        "get_service_events",
        "get_scheduled_changes",
        "get_affected_entities",
        "get_completed_events",
        "get_org_service_health",
        "get_org_affected_entities",
        "get_org_service_events",
        "get_org_account_events",
        "get_org_scheduled_changes",
        "get_org_account_events"
      ]
    },
    "awslabs.aws-api-mcp-server": {
      "command": "python3",
      "args": [
        "-m",
        "awslabs.aws_api_mcp_server.server"
      ],
      "env": {
        "AWS_REGION": "us-east-1"
      },
      "disabled": false,
      "autoApprove": []
    },
    "eks-mcp-server": {
      "command": "uvx",
      "args": [
        "awslabs.eks-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "autoApprove": [
        "list_api_versions"
      ]
    },
    "awslabs.cloudwatch-mcp-server": {
      "command": "uvx",
      "args": [
        "awslabs.cloudwatch-mcp-server@latest"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "autoApprove": [
        "execute_log_insights_query",
        "get_logs_insight_query_results",
        "describe_log_groups",
        "analyze_log_group"
      ]
    }
  }
}