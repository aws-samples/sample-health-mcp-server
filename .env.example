# AWS Configuration
# Copy this file to .env and fill in your AWS credentials

# Option 1: Use AWS Access Keys
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=your_session_token_here_if_using_temporary_credentials

# Option 2: Use AWS Profile (if you have AWS CLI configured)
AWS_PROFILE=your_aws_profile_name

# AWS Region
AWS_DEFAULT_REGION=us-east-1

# Optional: Enable debug logging
# AWS_HEALTH_DEBUG=true
